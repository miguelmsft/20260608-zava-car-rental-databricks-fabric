{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "zava/rentals",
  "title": "Rentals",
  "description": "Actual rental transactions (a specific vehicle handed to a customer). Central fact table. Drives fleet utilization, one-way flows, and is the parent of Payments.",
  "type": "object",
  "x-primary-key": "rental_id",
  "x-foreign-keys": {
    "reservation_id": "reservations.reservation_id (nullable: walk-ins have none)",
    "customer_id": "customers.customer_id",
    "vehicle_id": "vehicles.vehicle_id",
    "vehicle_class_id": "vehicle_classes.vehicle_class_id",
    "pickup_site_id": "sites.site_id",
    "return_site_id": "sites.site_id"
  },
  "required": ["rental_id", "customer_id", "vehicle_id", "vehicle_class_id", "pickup_site_id", "return_site_id", "pickup_ts", "planned_return_ts", "odometer_out", "is_one_way", "status"],
  "properties": {
    "rental_id": {"type": "string", "description": "PK, e.g. RN00000123."},
    "reservation_id": {"type": ["string", "null"], "description": "FK -> Reservations; null for walk-ins."},
    "customer_id": {"type": "string", "description": "FK -> Customers."},
    "vehicle_id": {"type": "string", "description": "FK -> Vehicles (specific car)."},
    "vehicle_class_id": {"type": "string", "description": "FK -> VehicleClasses."},
    "pickup_site_id": {"type": "string", "description": "FK -> Sites."},
    "return_site_id": {"type": "string", "description": "FK -> Sites; differs from pickup for one-way rentals."},
    "pickup_ts": {"type": "string", "format": "date-time", "description": "ISO-8601 UTC."},
    "planned_return_ts": {"type": "string", "format": "date-time"},
    "return_ts": {"type": ["string", "null"], "format": "date-time", "description": "null while status='open'."},
    "odometer_out": {"type": "integer"},
    "odometer_in": {"type": ["integer", "null"]},
    "miles_driven": {"type": ["integer", "null"]},
    "is_one_way": {"type": "boolean", "description": "pickup_site_id != return_site_id; drives the one-way-flow KPI."},
    "status": {"type": "string", "enum": ["open", "closed"]}
  }
}
