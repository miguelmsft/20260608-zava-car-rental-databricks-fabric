{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "zava/maintenance",
  "title": "Maintenance",
  "description": "Service / repair events per vehicle. Drives the maintenance-cost KPI and links to telematics fault codes.",
  "type": "object",
  "x-primary-key": "maintenance_id",
  "x-foreign-keys": {
    "vehicle_id": "vehicles.vehicle_id",
    "site_id": "sites.site_id"
  },
  "required": ["maintenance_id", "vehicle_id", "site_id", "maintenance_type", "opened_ts", "labor_cost_usd", "parts_cost_usd", "total_cost_usd", "odometer_at_service", "status"],
  "properties": {
    "maintenance_id": {"type": "string", "description": "PK, e.g. M0000123."},
    "vehicle_id": {"type": "string", "description": "FK -> Vehicles."},
    "site_id": {"type": "string", "description": "FK -> Sites (service location)."},
    "maintenance_type": {"type": "string", "description": "Oil Change, Brake Service, Engine Diagnostic, Recall, ..."},
    "fault_code": {"type": ["string", "null"], "description": "OBD-II-like code; correlates with Telematics.fault_code."},
    "opened_ts": {"type": "string", "format": "date-time"},
    "closed_ts": {"type": ["string", "null"], "format": "date-time", "description": "null while status='open'."},
    "labor_cost_usd": {"type": "number"},
    "parts_cost_usd": {"type": "number"},
    "total_cost_usd": {"type": "number", "description": "labor + parts; summed for the maintenance-cost KPI."},
    "odometer_at_service": {"type": "integer"},
    "status": {"type": "string", "enum": ["open", "closed"]}
  }
}
