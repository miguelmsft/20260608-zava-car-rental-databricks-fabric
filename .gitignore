# ---- Secrets & local environment (NEVER commit) ----
*.env
.env*
!.env.example
*.pem
*.key
*.pfx
*.publishsettings
secrets/
.secrets/
.azure/
.databrickscfg
azure.yaml.local
*.tfstate
*.tfstate.*
.terraform/

# ---- Real deployment config (commit only *.sample.json templates) ----
# Resolved configs carry environment-specific resource ids and must stay local.
deploy_config.json
databricks_config.json
**/config/deploy_config.json
**/config/databricks_config.json
*.local.json
# Defensive: always keep the committed templates tracked.
!*.sample.json

# ---- Bicep / Terraform parameter files with real (non-sample) values ----
# dev.bicepparam and existing-resources.bicepparam ship as placeholder templates
# and ARE tracked; copy them to *.local.bicepparam (ignored) for real deployments.
*.local.bicepparam
*.secrets.bicepparam
*.tfvars
*.tfvars.json

# ---- Orchestration / workflow artifacts (internal, not shipped) ----
demo-status.md
agent-reviews/
research/
archive/

# ---- Python ----
__pycache__/
*.py[cod]
.venv/
venv/
.ipynb_checkpoints/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ---- Node (if any tooling) ----
node_modules/

# ---- Build / temp ----
dist/
build/
*.log
.tmp/
tmp/
_tmp/

# ---- Generated demo data output & scratch (never commit) ----
data/output/

# ---- Compiled Bicep ARM output (validate with `bicep build --stdout`; do not commit) ----
infra/**/*.json

# ---- OS / editor ----
.DS_Store
Thumbs.db
.vscode/
.idea/
